env=staging

// Global MLflow params for staging
model_train_experiment_path='/Shared/olist-bad-reviews/staging/bad_review_experiment_staging'
model_name='olist_bad_reviews_staging'
model_deploy_experiment_path='/Shared/olist-bad-reviews/staging/bad_review_deployment_staging'

// Global Feature Store params
global_feature_store_database_name='feature_store'

// Local Feature Store params
local_feature_store_database_name='feature_store_bad_reviews_staging'

// Labels table params
labels_table_database_name='olist_bad_reviews_staging'
labels_table_name='labels'

// Batch inference predictions table params
predictions_table_database_name='olist_bad_reviews_staging'
predictions_table_name = 'bad_reviews_predictions'

// Reference table params - table to use for comparing staging vs production models
reference_table_database_name='olist_bad_reviews_staging'