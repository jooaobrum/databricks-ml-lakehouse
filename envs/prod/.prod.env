env=prod

// Global MLflow params for prod
model_train_experiment_path='/Shared/olist-bad-reviews/prod/bad_review_experiment_prod'
model_name='olist_bad_reviews_prod'
model_deploy_experiment_path='/Shared/olist-bad-reviews/prod/bad_review_deployment_prod'

// Global Feature Store params
global_feature_store_database_name='feature_store'

// Local Feature Store params
local_feature_store_database_name='feature_store_bad_reviews_prod'

// Table Feature Store params
feature_store_table_name='olist_customer_features'

// Features Store Description
feature_store_table_description= 'Customer features fetched from the global feature store to build the bad review model'

// Labels table params
labels_table_database_name='olist_bad_reviews_prod'
labels_table_name='labels'

// Batch inference predictions table params
predictions_table_database_name='olist_bad_reviews_prod'
predictions_table_name = 'bad_reviews_predictions'

// Reference table params - table to use for comparing staging vs production models
reference_table_database_name='olist_bad_reviews_prod'